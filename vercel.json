{
  "version": 2,
  "name": "pacifica-lens",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/pacifica(.*)", "dest": "/api/pacifica$1" },
    { "src": "/api/hyperliquid(/?.*)", "dest": "/api/hyperliquid.js" },
    { "src": "/api/elfa(/?.*)", "dest": "/api/elfa.js" },
    { "src": "/api/telegram(/?.*)", "dest": "/api/telegram.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
